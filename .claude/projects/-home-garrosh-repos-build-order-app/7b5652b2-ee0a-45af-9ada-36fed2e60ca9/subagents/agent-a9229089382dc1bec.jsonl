\n    29→\n    30→  return (\n    31→    <div className=\"tab-content\">\n    32→      {/* Glue Screen Buttons */}\n    33→      <div className=\"section-card\">\n    34→        <h2>Glue Screen Buttons (9-Slice Composited)</h2>\n    35→        <p className=\"section-desc\">Main menu buttons use 9-slice compositing: a 32x32 tiled background + a 256x32 border atlas (8 pieces of 32x32: TL, T, TR, R, BR, B, BL, L). Shared across all races.</p>\n    36→        <div className=\"glue-buttons-grid\">\n    37→          <div className=\"glue-btn-demo\">\n    38→            <GlueButton bgPath={GLUE_BG} borderPath={GLUE_BORDER} bgDownPath={GLUE_BG_DOWN} borderDownPath={GLUE_BORDER_DOWN} hoverPath={GLUE_HOVER} renderer={props.renderer}>\n    39→              <div className=\"gb-label\"><span className=\"hotkey\">S</span>ingle Player</div>\n    40→            </GlueButton>\n    41→            <div className=\"glue-btn-state-label\">Normal</div>\n    42→          </div>\n    43→          <div className=\"glue-btn-demo\">\n    44→            <GlueButton bgPath={GLUE_BG} borderPath={GLUE_BORDERED} bgDownPath={GLUE_BG_DOWN} borderDownPath={GLUE_BORDERED_DOWN} hoverPath={GLUE_HOVER} renderer={props.renderer}>\n    45→              <div className=\"gb-label\"><span className=\"hotkey\">S</span>ingle Player</div>\n    46→            </GlueButton>\n    47→            <div className=\"glue-btn-state-label\">Bordered</div>\n    48→          </div>\n    49→          <div className=\"glue-btn-demo\">\n    50→            <GlueButton bgPath={GLUE_BG_DISABLED} borderPath={GLUE_BORDER_DISABLED} disabled renderer={props.renderer}>\n    51→              <div className=\"gb-label\" style={{ opacity: 0.5 }}>Single Player</div>\n    52→            </GlueButton>\n    53→            <div className=\"glue-btn-state-label\">Disabled</div>\n    54→          </div>\n    55→        </div>\n    56→\n    57→        <h3 style={{ marginTop: '28px', color: 'var(--wc3-gold)', textShadow: 'var(--wc3-shadow)' }}>Main Menu Buttons</h3>\n    58→        <p className=\"section-desc\">In the game, 9-slice buttons are drawn inside pre-rendered border frames (BackdropBackground stretched with BackdropBlendAll). The GLUETEXTBUTTON is a child of the base BACKDROP frame.</p>\n    59→        <div className=\"glue-menu-grid\">\n    60→          {MENU_LABELS.map((label) => {\n    61→            const hotkey = label[0];\n    62→            const rest = label.slice(1);\n    63→            return (\n    64→              <MenuButton key={label} frameSrc={GLUE_FRAME} bgPath={GLUE_BG} borderPath={GLUE_BORDER} bgDownPath={GLUE_BG_DOWN} borderDownPath={GLUE_BORDER_DOWN} hoverPath={GLUE_HOVER} renderer={props.renderer}>\n    65→                <div className=\"gb-label\"><span className=\"hotkey\">{hotkey}</span>{rest}</div>\n    66→              </MenuButton>\n    67→            );\n    68→          })}\n    69→        </div>\n    70→      </div>\n    71→\n    72→      {/* EscMenu Option Buttons */}\n    73→      <div className=\"section-card\">\n    74→        <h2>EscMenu Option Buttons</h2>\n    75→        <p className=\"section-desc\">Race-specific option buttons with background + border + highlight layers.</p>\n    76→        <div style={{ display: 'flex', flexWrap: 'wrap', gap: '8px', justifyContent: 'center' }}>\n    77→          {['Save Game', 'Options', 'End Game'].map((label) =>\n    78→            <OptionButton key={label} label={label} renderer={props.renderer} />\n    79→          )}\n    80→        </div>\n    81→      </div>\n    82→\n    83→      {/* Console Buttons */}\n    84→      <div className=\"section-card\">\n    85→        <h2>Console Buttons</h2>\n    86→        <p className=\"section-desc\">Minimap controls, formation toggles, and command button grid from the in-game HUD console.</p>\n    87→        <div className=\"console-buttons-grid\">\n    88→          <ConsoleButtonGroup title=\"Minimap - Ally\" items={[\n    89→            { src: `${consoleBtnPath}-minimap-ally-active.png`, label: 'Active' },\n    90→            { src: `${consoleBtnPath}-minimap-ally-disabled.png`, label: 'Disabled' },\n    91→            { src: `${consoleBtnPath}-minimap-ally-active-down.png`, label: 'Down' },\n    92→          ]} />\n    93→          <ConsoleButtonGroup title=\"Minimap - Ping\" items={[\n    94→            { src: `${consoleBtnPath}-minimap-ping-active.png`, label: 'Active' },\n    95→            { src: `${consoleBtnPath}-minimap-ping-disabled.png`, label: 'Disabled' },\n    96→            { src: `${consoleBtnPath}-minimap-ping-active-down.png`, label: 'Down' },\n    97→          ]} />\n    98→          <ConsoleButtonGroup title=\"Minimap - Terrain\" items={[\n    99→            { src: `${consoleBtnPath}-minimap-terrain-active.png`, label: 'Active' },\n   100→            { src: `${consoleBtnPath}-minimap-terrain-disabled.png`, label: 'Disabled' },\n   101→            { src: `${consoleBtnPath}-minimap-terrain-active-down.png`, label: 'Down' },\n   102→          ]} />\n   103→          <ConsoleButtonGroup title=\"Formation\" items={[\n   104→            { src: `${consoleBtnPath}-formation-on.png`, label: 'On' },\n   105→            { src: `${consoleBtnPath}-formation-off.png`, label: 'Off' },\n   106→            { src: `${consoleBtnPath}-formation-on-down.png`, label: 'On Down' },\n   107→            { src: `${consoleBtnPath}-formation-off-down.png`, label: 'Off Down' },\n   108→          ]} />\n   109→          <ConsoleButtonGroup title=\"Console Buttons\" items={[\n   110→            { src: `${cmdBtnPath}-up.png`, label: 'Up' },\n   111→            { src: `${cmdBtnPath}-down.png`, label: 'Down' },\n   112→            { src: `${cmdBtnPath}-highlight.png`, label: 'Highlight' },\n   113→            { src: `${cmdBtnPath}-back-active.png`, label: 'Back' },\n   114→            { src: `${cmdBtnPath}-back-disabled.png`, label: 'Back Off' },\n   115→          ]} />\n   116→        </div>\n   117→\n   118→        <h3>Command Button Grid</h3>\n   119→        <div style={{ textAlign: 'center' }}>\n   120→          <div className=\"command-grid\">\n   121→            {Array(12).fill(null).map((_, i) =>\n   122→              <div key={i} className=\"command-cell\">\n   123→                <img src={`war3/Widgets/Console/${race}/CommandButton/${rp.lower}-activebutton.png`} alt=\"\" />\n   124→              </div>\n   125→            )}\n   126→          </div>\n   127→          <div style={{ display: 'flex', gap: '8px', justifyContent: 'center', marginTop: '10px' }}>\n   128→            <div className=\"tooltip-res-card\">\n   129→              <img src={`war3/Widgets/Console/${race}/CommandButton/${rp.lower}-activebutton.png`} style={{ width: '48px', height: '48px', border: '1px solid var(--card-border)', borderRadius: '2px' }} />\n   130→              <div className=\"res-label\">Active Button</div>\n   131→            </div>\n   132→            <div className=\"tooltip-res-card\">\n   133→              <img src={`war3/Widgets/Console/${race}/CommandButton/${rp.lower}-multipleselection-border.png`} style={{ width: '48px', height: '48px', border: '1px solid var(--card-border)', borderRadius: '2px' }} />\n   134→              <div className=\"res-label\">Selection</div>\n   135→            </div>\n   136→            <div className=\"tooltip-res-card\">\n   137→              <img src={`war3/Widgets/Console/${race}/CommandButton/${rp.lower}-multipleselection-heroglow.png`} style={{ width: '48px', height: '48px', border: '1px solid var(--card-border)', borderRadius: '2px' }} />\n   138→              <div className=\"res-label\">Hero Glow</div>\n   139→            </div>\n   140→            <div className=\"tooltip-res-card\">\n   141→              <img src={`war3/Widgets/Console/${race}/CommandButton/${rp.lower}-subgroup-background.png`} style={{ width: '48px', height: '48px', border: '1px solid var(--card-border)', borderRadius: '2px' }} />\n   142→              <div className=\"res-label\">Subgroup BG</div>\n   143→ 