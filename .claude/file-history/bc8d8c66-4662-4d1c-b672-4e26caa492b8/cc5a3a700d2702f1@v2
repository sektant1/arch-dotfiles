import { useState, useEffect, useRef } from 'react';
import type { Renderer } from '../renderer/Renderer';

interface Props {
  label: string;
  initialChecked?: boolean;
  renderer: Renderer;
}

export default function Checkbox(props: Props) {
  const ref = useRef<HTMLDivElement>(null);
  const visualRef = useRef<HTMLDivElement>(null);
  const [checked, setChecked] = useState(props.initialChecked ?? false);

  useEffect(() => {
    props.renderer.checkboxes.push({
      ref: () => ref.current!,
      visualRef: () => visualRef.current!,
      checked: () => checked,
    });
  }, []);

  return (
    <div
      ref={ref}
      className={`wc3-checkbox${checked ? ' checked' : ''}`}
      onClick={() => setChecked(v => !v)}
    >
      <div ref={visualRef} className="cb-visual">
        <img className="cb-bg" src="" alt="" />
        <img className="cb-check" src="" alt="" />
      </div>
      <span className="cb-label">{props.label}</span>
    </div>
  );
}
