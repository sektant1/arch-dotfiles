import { useEffect, useRef, type ReactNode } from 'react';
import type { Renderer } from '../renderer/Renderer';

interface Props {
  children: ReactNode;
  renderer: Renderer;
}

export default function Tooltip(props: Props) {
  const ref = useRef<HTMLDivElement>(null);

  useEffect(() => {
    props.renderer.tooltips.push({ ref: () => ref.current! });
  }, []);

  return (
    <div ref={ref} className="wc3-tooltip">
      <div className="tt-content">{props.children}</div>
    </div>
  );
}
