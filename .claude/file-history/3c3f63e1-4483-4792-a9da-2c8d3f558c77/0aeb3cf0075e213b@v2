import React, { useState, useRef, useEffect, useCallback } from "react";
import { loadBlpImage } from "../utils/blp";
import { EDITBOX_ASSETS, SCROLLBAR_ASSETS } from "../utils/assets";
import { useBlpTexture } from "../hooks/useBlpTexture";

export interface ListboxProps {
  items: string[];
  selectedIndex?: number;
  onSelect?: (index: number) => void;
  /** Number of visible rows */
  visibleRows?: number;
  className?: string;
}

/**
 * Scrollable list with WC3-styled chrome, scrollbar, and selection highlight.
 */
export function Listbox({
  items,
  selectedIndex = -1,
  onSelect,
  visibleRows = 6,
  className,
}: ListboxProps) {
  const [scrollOffset, setScrollOffset] = useState(0);
  const canvasRef = useRef<HTMLCanvasElement>(null);
  const scrollCanvasRef = useRef<HTMLCanvasElement>(null);

  const upArrowUrl = useBlpTexture(SCROLLBAR_ASSETS.upArrow);
  const downArrowUrl = useBlpTexture(SCROLLBAR_ASSETS.downArrow);
  const knobUrl = useBlpTexture(SCROLLBAR_ASSETS.knob);

  const rowHeight = 20;
  const maxScroll = Math.max(0, items.length - visibleRows);

  const drawBox = useCallback(async () => {
    const canvas = canvasRef.current;
    if (!canvas) return;
    const ctx = canvas.getContext("2d");
    if (!ctx) return;
    try {
      const [bg, border] = await Promise.all([
        loadBlpImage(EDITBOX_ASSETS.escBackground),
        loadBlpImage(EDITBOX_ASSETS.escBorder),
      ]);
      const w = canvas.width;
      const h = canvas.height;
      ctx.clearRect(0, 0, w, h);
      ctx.imageSmoothingEnabled = false;
      ctx.drawImage(bg, 0, 0, w, h);
      ctx.drawImage(border, 0, 0, w, h);
    } catch {}
  }, []);

  const drawScroll = useCallback(async () => {
    const canvas = scrollCanvasRef.current;
    if (!canvas) return;
    const ctx = canvas.getContext("2d");
    if (!ctx) return;
    try {
      const [bg, border] = await Promise.all([
        loadBlpImage(SCROLLBAR_ASSETS.bg),
        loadBlpImage(SCROLLBAR_ASSETS.border),
      ]);
      const w = canvas.width;
      const h = canvas.height;
      ctx.clearRect(0, 0, w, h);
      ctx.imageSmoothingEnabled = false;
      ctx.drawImage(bg, 0, 0, w, h);
      ctx.drawImage(border, 0, 0, w, h);
    } catch {}
  }, []);

  useEffect(() => { drawBox(); drawScroll(); }, [drawBox, drawScroll]);

  const scrollPercent = maxScroll > 0 ? (scrollOffset / maxScroll) * 100 : 0;
  const visibleItems = items.slice(scrollOffset, scrollOffset + visibleRows);

  return (
    <div className={`wc3-listbox-demo ${className ?? ""}`}>
      <div className="wc3-listbox-shell">
        <canvas ref={canvasRef} className="wc3-listbox-canvas" width={496} height={272} />
        <div className="wc3-listbox-mask">
          <div
            className="wc3-listbox-items"
            style={{ transform: `translateY(0px)` }}
          >
            {visibleItems.map((item, i) => {
              const realIndex = scrollOffset + i;
              return (
                <button
                  key={realIndex}
                  type="button"
                  className={`wc3-listbox-item${realIndex === selectedIndex ? " wc3-listbox-item--selected" : ""}`}
                  onClick={() => onSelect?.(realIndex)}
                >
                  {item}
                </button>
              );
            })}
          </div>
        </div>
      </div>
      <div className="wc3-listbox-scrollbar">
        <button
          className="wc3-listbox-scroll-arrow"
          onClick={() => setScrollOffset((v) => Math.max(0, v - 1))}
          disabled={scrollOffset <= 0}
          aria-label="Scroll up"
        >
          {upArrowUrl && <img src={upArrowUrl} alt="" />}
        </button>
        <div className="wc3-listbox-scroll">
          <canvas ref={scrollCanvasRef} className="wc3-listbox-scroll-canvas" width={36} height={192} />
          <div
            className="wc3-listbox-scroll-thumb"
            style={{
              top: `${scrollPercent}%`,
              backgroundImage: knobUrl ? `url("${knobUrl}")` : undefined,
            }}
          />
          <input
            type="range"
            min={0}
            max={maxScroll}
            value={scrollOffset}
            onChange={(e) => setScrollOffset(Number(e.target.value))}
            aria-label="List scroll position"
            style={{ writingMode: "vertical-lr" as any }}
          />
        </div>
        <button
          className="wc3-listbox-scroll-arrow"
          onClick={() => setScrollOffset((v) => Math.min(maxScroll, v + 1))}
          disabled={scrollOffset >= maxScroll}
          aria-label="Scroll down"
        >
          {downArrowUrl && <img src={downArrowUrl} alt="" />}
        </button>
      </div>
    </div>
  );
}
