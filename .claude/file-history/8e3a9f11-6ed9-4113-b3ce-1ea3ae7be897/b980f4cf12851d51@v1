import type { Race } from "../types";

/** Faction-specific ESC menu button assets */
export function getEscButtonAssets(race: Race) {
  if (race === "Human") {
    return {
      bg: "/buttons/esc/human/human-options-menu-background.blp",
      borderUp: "/buttons/esc/human/human-options-button-border-up.blp",
      borderDown: "/buttons/esc/human/human-options-button-border-down.blp",
      highlight: "/buttons/esc/human/human-options-button-highlight.blp",
      disabledBg:
        "/buttons/esc/human/human-options-button-background-disabled.blp",
    };
  }
  if (race === "Orc") {
    return {
      bg: "/buttons/esc/orc/orc-options-button-background.blp",
      borderUp: "/buttons/esc/human/human-options-button-border-up.blp",
      borderDown: "/buttons/esc/orc/orc-options-button-background-down.blp",
      highlight: "/buttons/esc/orc/orc-options-button-highlight.blp",
      disabledBg:
        "/buttons/esc/human/human-options-button-background-disabled.blp",
    };
  }
  if (race === "NightElf") {
    return {
      bg: "/buttons/esc/nightelf/nightelf-options-button-background.blp",
      borderUp: "/buttons/esc/human/human-options-button-border-up.blp",
      borderDown:
        "/buttons/esc/nightelf/nightelf-options-button-background-down.blp",
      highlight: "/buttons/esc/nightelf/nightelf-options-button-highlight.blp",
      disabledBg:
        "/buttons/esc/human/human-options-button-background-disabled.blp",
    };
  }
  // Undead
  return {
    bg: "/buttons/esc/undead/undead-options-button-background.blp",
    borderUp: "/buttons/esc/human/human-options-button-border-up.blp",
    borderDown: "/buttons/esc/undead/undead-options-button-background-down.blp",
    highlight: "/buttons/esc/undead/undead-options-button-highlight.blp",
    disabledBg:
      "/buttons/esc/undead/undead-options-button-background-disabled.blp",
  };
}

/** Faction-specific ESC menu border */
export function getEscMenuBorder(race: Race): string {
  if (race === "Orc") return "/buttons/esc/orc/orc-options-menu-border.blp";
  if (race === "NightElf")
    return "/buttons/esc/nightelf/nightelf-options-menu-border.blp";
  if (race === "Undead")
    return "/buttons/esc/undead/undead-options-menu-border.blp";
  return "/buttons/esc/human/human-options-menu-border.blp";
}

/** Faction-specific checkbox depressed texture */
export function getCheckboxDepressed(race: Race): string {
  if (race === "Orc") return "/buttons/checkbox/orc-checkbox-depressed.blp";
  if (race === "NightElf")
    return "/buttons/checkbox/nightelf-checkbox-depressed.blp";
  if (race === "Undead")
    return "/buttons/checkbox/undead-checkbox-depressed.blp";
  return "/buttons/checkbox/checkbox-depressed.blp";
}

/** Faction-specific slider knob */
export function getSliderKnob(race: Race): string {
  if (race === "Orc") return "/buttons/slider/orc-slider-knob.blp";
  if (race === "NightElf") return "/buttons/slider/nightelf-slider-knob.blp";
  if (race === "Undead") return "/buttons/slider/undead-slider-knob.blp";
  return "/buttons/slider/slider-knob.blp";
}

/** Faction-specific worker unit icon */
export function getWorkerIcon(race: Race): string {
  if (race === "Human") return "/buttons/command/BTNPeasant.blp";
  if (race === "NightElf") return "/buttons/command/BTNWisp.blp";
  if (race === "Undead") return "/buttons/command/BTNAcolyte.blp";
  return "/buttons/command/BTNPeon.blp";
}

/** Cinematic border per race */
export function getCinematicBorder(race: Race): string {
  if (race === "Orc") return "/borders/esc/orc-cinematic-border.blp";
  if (race === "NightElf") return "/borders/esc/nightelf-cinematic-border.blp";
  if (race === "Undead") return "/borders/esc/undead-cinematic-border.blp";
  return "/borders/esc/human-cinematic-border.blp";
}

