import type { Race } from "../types";

/** Faction-specific ESC menu button assets */
export function getEscButtonAssets(race: Race) {
  if (race === "Human") {
    return {
      bg: "/assets/esc/human/human-options-menu-background.png",
      borderUp: "/assets/esc/human/human-options-button-border-up.png",
      borderDown: "/assets/esc/human/human-options-button-border-down.png",
      highlight: "/assets/esc/human/human-options-button-highlight.png",
      disabledBg:
        "/assets/esc/human/human-options-button-background-disabled.png",
    };
  }
  if (race === "Orc") {
    return {
      bg: "/assets/esc/orc/orc-options-button-background.png",
      borderUp: "/assets/esc/human/human-options-button-border-up.png",
      borderDown: "/assets/esc/orc/orc-options-button-background-down.png",
      highlight: "/assets/esc/orc/orc-options-button-highlight.png",
      disabledBg:
        "/assets/esc/human/human-options-button-background-disabled.png",
    };
  }
  if (race === "NightElf") {
    return {
      bg: "/assets/esc/nightelf/nightelf-options-button-background.png",
      borderUp: "/assets/esc/human/human-options-button-border-up.png",
      borderDown:
        "/assets/esc/nightelf/nightelf-options-button-background-down.png",
      highlight: "/assets/esc/nightelf/nightelf-options-button-highlight.png",
      disabledBg:
        "/assets/esc/human/human-options-button-background-disabled.png",
    };
  }
  // Undead
  return {
    bg: "/assets/esc/undead/undead-options-button-background.png",
    borderUp: "/assets/esc/human/human-options-button-border-up.png",
    borderDown: "/assets/esc/undead/undead-options-button-background-down.png",
    highlight: "/assets/esc/undead/undead-options-button-highlight.png",
    disabledBg:
      "/assets/esc/undead/undead-options-button-background-disabled.png",
  };
}

/** Faction-specific ESC menu border */
export function getEscMenuBorder(race: Race): string {
  if (race === "Orc") return "/assets/esc/orc/orc-options-menu-border.png";
  if (race === "NightElf")
    return "/assets/esc/nightelf/nightelf-options-menu-border.png";
  if (race === "Undead")
    return "/assets/esc/undead/undead-options-menu-border.png";
  return "/assets/esc/human/human-options-menu-border.png";
}

/** Faction-specific checkbox depressed texture */
export function getCheckboxDepressed(race: Race): string {
  if (race === "Orc") return "/assets/checkbox/orc-checkbox-depressed.png";
  if (race === "NightElf")
    return "/assets/checkbox/nightelf-checkbox-depressed.png";
  if (race === "Undead")
    return "/assets/checkbox/undead-checkbox-depressed.png";
  return "/assets/checkbox/checkbox-depressed.png";
}

/** Faction-specific slider knob */
export function getSliderKnob(race: Race): string {
  if (race === "Orc") return "/assets/slider/orc-slider-knob.png";
  if (race === "NightElf") return "/assets/slider/nightelf-slider-knob.png";
  if (race === "Undead") return "/assets/slider/undead-slider-knob.png";
  return "/assets/slider/slider-knob.png";
}

/** Faction-specific worker unit icon */
export function getWorkerIcon(race: Race): string {
  if (race === "Human") return "/assets/command/BTNPeasant.png";
  if (race === "NightElf") return "/assets/command/BTNWisp.png";
  if (race === "Undead") return "/assets/command/BTNAcolyte.png";
  return "/assets/command/BTNPeon.png";
}

/** Cinematic border per race */
export function getCinematicBorder(race: Race): string {
  if (race === "Orc") return "/assets/borders/orc-cinematic-border.png";
  if (race === "NightElf") return "/assets/borders/nightelf-cinematic-border.png";
  if (race === "Undead") return "/assets/borders/undead-cinematic-border.png";
  return "/assets/borders/human-cinematic-border.png";
}

