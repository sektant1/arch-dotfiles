* {
  box-sizing: border-box;
}

html,
body,
#root {
  margin: 0;
  width: 100%;
  height: 100%;
}

body {
  background: #08080f;
  color: #fff;
  font-family:
    Friz Quadrata,
    Palatino Linotype,
    Book Antiqua,
    Palatino,
    serif;
}

/* ── Layout ───────────────────────────────────────────── */
.demo-layout {
  display: flex;
  height: 100vh;
  overflow: hidden;
}

/* ── Sidebar ──────────────────────────────────────────── */
.demo-sidebar {
  width: 220px;
  min-width: 220px;
  background: #0c0c16;
  border-right: 1px solid #1a1a2a;
  display: flex;
  flex-direction: column;
  overflow-y: auto;
}

.demo-sidebar::-webkit-scrollbar {
  width: 4px;
}
.demo-sidebar::-webkit-scrollbar-track {
  background: transparent;
}
.demo-sidebar::-webkit-scrollbar-thumb {
  background: #222;
  border-radius: 2px;
}

.demo-sidebar-header {
  padding: 24px 20px 16px;
  border-bottom: 1px solid #1a1a2a;
}

.demo-logo {
  margin: 0;
  font-size: 1.1rem;
  color: #fcd312;
  text-shadow: 1px 1px 0 rgba(0, 0, 0, 0.9);
  letter-spacing: 0.5px;
}

.demo-subtitle {
  display: block;
  font-size: 0.7rem;
  color: #555;
  margin-top: 2px;
  letter-spacing: 0.3px;
}

.demo-sidebar-race {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4px;
  padding: 12px 12px 8px;
  border-bottom: 1px solid #1a1a2a;
}

.demo-race-btn {
  border: 1px solid #282838;
  border-radius: 4px;
  background: #111118;
  color: #7b818d;
  padding: 5px 0;
  font-family: inherit;
  font-size: 0.72rem;
  cursor: pointer;
  transition:
    background 0.15s,
    color 0.15s,
    border-color 0.15s;
  text-align: center;
}

.demo-race-btn:hover {
  background: #1a1a28;
  color: #d3ddfb;
}

.demo-race-btn--active {
  background: #1e1e30;
  color: #fcd312;
  border-color: #fcd312;
}

/* ── Navigation ───────────────────────────────────────── */
.demo-nav {
  display: flex;
  flex-direction: column;
  padding: 8px 0;
  flex: 1;
}

.demo-nav-link {
  display: block;
  padding: 7px 20px;
  color: #666;
  text-decoration: none;
  font-size: 0.8rem;
  transition:
    color 0.15s,
    background 0.15s;
  border-left: 2px solid transparent;
}

.demo-nav-link:hover {
  color: #bbb;
  background: rgba(255, 255, 255, 0.02);
}

.demo-nav-link--active {
  color: #fcd312;
  border-left-color: #fcd312;
  background: rgba(252, 211, 18, 0.04);
}

/* ── Main content ─────────────────────────────────────── */
.demo-main {
  flex: 1;
  overflow-y: auto;
  padding: 32px 40px;
  scroll-behavior: smooth;
}

.demo-main::-webkit-scrollbar {
  width: 8px;
}
.demo-main::-webkit-scrollbar-track {
  background: #0a0a14;
}
.demo-main::-webkit-scrollbar-thumb {
  background: #222;
  border-radius: 4px;
}

/* ── Sections ─────────────────────────────────────────── */
.demo-section {
  max-width: 820px;
  margin-bottom: 48px;
  scroll-margin-top: 24px;
}

.demo-section h2 {
  margin: 0 0 6px;
  font-size: 1.2rem;
  color: #fff;
  text-shadow: 1px 1px 0 rgba(0, 0, 0, 0.9);
  padding-bottom: 8px;
  border-bottom: 1px solid #1a1a2a;
}

.demo-section h2 .demo-label {
  font-weight: normal;
}

.demo-desc {
  margin: 8px 0 16px;
  color: #555;
  font-size: 0.82rem;
  line-height: 1.5;
}

/* ── Cards ────────────────────────────────────────────── */
.demo-card {
  background: #0e0e18;
  border: 1px solid #1a1a2a;
  border-radius: 8px;
  padding: 20px;
  margin-bottom: 12px;
}

.demo-card-title {
  color: #fcd312;
  margin: 0 0 12px;
  font-size: 0.9rem;
}

.demo-card-title .demo-label {
  font-weight: normal;
}

/* ── Rows & columns ───────────────────────────────────── */
.demo-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  align-items: flex-start;
}

.demo-col {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}

.demo-label {
  font-size: 0.7rem;
  color: #555;
  margin-top: 4px;
}

/* ── Controls row ─────────────────────────────────────── */
.demo-controls-row {
  display: flex;
  gap: 16px;
  align-items: center;
  flex-wrap: wrap;
  margin-bottom: 12px;
}

.demo-slider-wrap {
  display: flex;
  align-items: center;
  gap: 8px;
  color: #666;
  font-size: 0.8rem;
}

.demo-slider-wrap input[type="range"] {
  width: 140px;
  accent-color: #fcd312;
}

/* ── Footer ───────────────────────────────────────────── */
.demo-footer {
  text-align: center;
  padding: 40px 0 24px;
  color: #2a2a3a;
  font-size: 0.72rem;
  letter-spacing: 0.5px;
}

/* ── Chat input row for demo ──────────────────────────── */
.demo-chat-input {
  display: flex;
  gap: 8px;
  margin-top: 8px;
}

.demo-chat-input input {
  flex: 1;
  border: 1px solid #2a3453;
  border-radius: 4px;
  background: #0a0f1c;
  color: #dce5fb;
  font-family: inherit;
  padding: 7px 9px;
}

.demo-chat-input button {
  border: 1px solid #43527b;
  border-radius: 4px;
  background: #111a30;
  color: #dce5fb;
  font-family: inherit;
  padding: 7px 12px;
  cursor: pointer;
}
