#pragma once

#include <rts/core/types.hpp>

namespace rts {

struct CameraConfig {
    f32 fov            = 45.0f;
    f32 near_plane     = 0.1f;
    f32 far_plane      = 500.0f;
    f32 distance       = 30.0f;
    f32 min_distance   = 10.0f;
    f32 max_distance   = 80.0f;
    f32 pitch          = -55.0f;   // graus, ângulo top-down estilo WC3
    f32 pan_speed      = 20.0f;
    f32 zoom_speed     = 5.0f;
    f32 edge_pan_margin = 20.0f;   // pixels da borda da tela para acionar pan
};

class RtsCamera {
public:
    explicit RtsCamera(const CameraConfig& config = {});

    void update(f32 delta_time, const Vec2& mouse_pos, const Vec2& screen_size,
                bool key_w, bool key_a, bool key_s, bool key_d, f32 scroll_delta);

    void pan(const Vec2& offset);
    void zoom(f32 delta);
    void set_aspect_ratio(f32 aspect);
    void set_target(const Vec3& t) { m_target = t; }

    Mat4 view_matrix()       const;
    Mat4 projection_matrix() const;
    Vec3 target()            const { return m_target; }

private:
    Vec3         m_target{0.0f, 0.0f, 0.0f};
    f32          m_distance;
    f32          m_pitch;
    f32          m_aspect_ratio = 16.0f / 9.0f;
    CameraConfig m_config;

    Vec3 calculate_position() const;
};

}  // namespace rts
