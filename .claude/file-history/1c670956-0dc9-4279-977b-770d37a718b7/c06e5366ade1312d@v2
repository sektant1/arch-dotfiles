#include <gtest/gtest.h>
#include <rts/core/logger.hpp>

TEST(LoggerTest, InitializeDoesNotThrow) {
    EXPECT_NO_THROW(rts::Logger::init());
}

TEST(LoggerTest, InitializeTwiceDoesNotThrow) {
    rts::Logger::init();
    EXPECT_NO_THROW(rts::Logger::init());
}

TEST(LoggerTest, LogAfterInit) {
    rts::Logger::init();
    EXPECT_NO_THROW(RTS_LOG_INFO("test message {}", 42));
}
