#pragma once

#include <rts/core/types.hpp>

struct GLFWwindow;

namespace rts {

class Input {
public:
    explicit Input(GLFWwindow* window);

    bool is_key_pressed(int key) const;
    bool is_mouse_button_pressed(int button) const;
    Vec2 mouse_position() const;
    Vec2 mouse_delta() const;
    f32  scroll_delta() const;

    void update();

private:
    static void scroll_callback(GLFWwindow* window, double xoffset, double yoffset);

    GLFWwindow* m_window = nullptr;
    Vec2 m_last_mouse_pos{0.0f, 0.0f};
    Vec2 m_mouse_delta{0.0f, 0.0f};
    f32  m_scroll_delta = 0.0f;
    f32  m_scroll_accumulator = 0.0f;
};

}  // namespace rts
