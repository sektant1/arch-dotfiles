#pragma once

#include <spdlog/spdlog.h>
#include <memory>

namespace rts {

class Logger {
public:
    static void init();
    static std::shared_ptr<spdlog::logger>& get();

private:
    static std::shared_ptr<spdlog::logger> s_logger;
};

}  // namespace rts

#define RTS_LOG_TRACE(...)    do { if (::rts::Logger::get()) ::rts::Logger::get()->trace(__VA_ARGS__);    } while(0)
#define RTS_LOG_DEBUG(...)    do { if (::rts::Logger::get()) ::rts::Logger::get()->debug(__VA_ARGS__);    } while(0)
#define RTS_LOG_INFO(...)     do { if (::rts::Logger::get()) ::rts::Logger::get()->info(__VA_ARGS__);     } while(0)
#define RTS_LOG_WARN(...)     do { if (::rts::Logger::get()) ::rts::Logger::get()->warn(__VA_ARGS__);     } while(0)
#define RTS_LOG_ERROR(...)    do { if (::rts::Logger::get()) ::rts::Logger::get()->error(__VA_ARGS__);    } while(0)
#define RTS_LOG_CRITICAL(...) do { if (::rts::Logger::get()) ::rts::Logger::get()->critical(__VA_ARGS__); } while(0)
