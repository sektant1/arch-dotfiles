#pragma once

#include <rts/core/types.hpp>

namespace rts {

class Texture {
public:
    Texture(const u8* data, u32 width, u32 height, u32 channels);
    ~Texture();

    Texture(const Texture&) = delete;
    Texture& operator=(const Texture&) = delete;
    Texture(Texture&& other) noexcept;
    Texture& operator=(Texture&& other) noexcept;

    void bind(u32 slot = 0) const;
    void unbind() const;

    u32 id()     const { return m_texture; }
    u32 width()  const { return m_width; }
    u32 height() const { return m_height; }

private:
    u32 m_texture = 0;
    u32 m_width   = 0;
    u32 m_height  = 0;
};

}  // namespace rts
