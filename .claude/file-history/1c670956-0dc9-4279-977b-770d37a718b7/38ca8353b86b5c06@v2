#pragma once

#include <rts/core/types.hpp>
#include <string>
#include <vector>

namespace rts {

struct TextureData {
    std::vector<u8> pixels;
    u32             width    = 0;
    u32             height   = 0;
    u32             channels = 0;
};

class ITextureLoader {
public:
    virtual ~ITextureLoader() = default;
    virtual TextureData load(const std::string& path) = 0;
};

}  // namespace rts
